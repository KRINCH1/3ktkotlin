# Database Configuration
DB_URL=jdbc:h2:file:./data/authdb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
DB_DRIVER=org.h2.Driver
DB_USER=sa
DB_PASSWORD=

# JWT Configuration
